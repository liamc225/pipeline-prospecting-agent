# Optional demo token for hosted/private playground access
DEMO_ACCESS_TOKEN=your-demo-token

# Anthropic API (for enrichment step)
ANTHROPIC_API_KEY=sk-ant-...

# Search provider for company/contact enrichment
SEARCH_PROVIDER=tavily

# Tavily API (default web search provider during enrichment)
TAVILY_API_KEY=tvly-...

# Exa API (optional alternative web search provider during enrichment)
EXA_API_KEY=exa-...

# Trigger.dev secret key (for triggering tasks + retrieving run status)
TRIGGER_SECRET_KEY=tr_dev_...
